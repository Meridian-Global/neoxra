# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# App
ENVIRONMENT=development
LOG_LEVEL=info
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/neoxra

# Optional: platform publishing (day 9+)
# INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=your_linkedin_personal_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_person_id

# Gmail idea scanner
# 1. Create a project at console.cloud.google.com
# 2. Enable the Gmail API
# 3. Create OAuth credentials (Desktop app) and download as credentials.json
# 4. Run: cd backend && python scripts/gmail_auth.py
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Neoxra runtime
NEOXRA_ENV_MODE=local
NEOXRA_CORE_CLIENT_MODE=local
NEOXRA_CORE_API_BASE_URL=
NEOXRA_CORE_KEY_ID=neoxra-backend
NEOXRA_CORE_SHARED_SECRET=
NEOXRA_RATE_LIMIT_BACKEND=memory
NEOXRA_REDIS_URL=
NEOXRA_ADMIN_KEY=
CORS_ALLOWED_ORIGINS=https://neoxra.com,https://www.neoxra.com,http://localhost:3000
NEOXRA_CORE_GIT_URL=https://github.com/Meridian-Global/neoxra-core.git
NEOXRA_CORE_GIT_REF=main
# Required in Render if neoxra-core is private
GITHUB_TOKEN=

# Auth
FRONTEND_APP_URL=http://localhost:3000
AUTH_MAGIC_LINK_TTL_MINUTES=20
AUTH_SESSION_TTL_DAYS=14
AUTH_MAGIC_LINK_DEBUG=false

# Google OAuth
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/login/google/callback

# Demo access
NEOXRA_DEMO_SIGNING_SECRET=replace_me_for_demo_tokens
NEOXRA_DEMO_TOKEN_TTL_SECONDS=28800
NEOXRA_LANDING_DEMO_ACCESS_MODE=public
NEOXRA_INSTAGRAM_DEMO_ACCESS_MODE=public
NEOXRA_LEGAL_DEMO_ACCESS_MODE=public
NEOXRA_LEGAL_DEMO_ACCESS_CODE=replace_me_for_client_demo

# Generation safety limits
CORE_RUN_RATE_LIMIT_PER_MINUTE=12
CORE_RUN_MAX_CONCURRENT_PER_IP=1
CORE_RUN_MAX_BODY_BYTES=8192
CORE_RUN_MAX_IDEA_LENGTH=400
CORE_RUN_MAX_VOICE_PROFILE_LENGTH=64
INSTAGRAM_GENERATE_RATE_LIMIT_PER_MINUTE=20
INSTAGRAM_GENERATE_MAX_CONCURRENT_PER_IP=2
INSTAGRAM_GENERATE_MAX_BODY_BYTES=16384
INSTAGRAM_MAX_TOPIC_LENGTH=240
INSTAGRAM_MAX_TEMPLATE_TEXT_LENGTH=2000
INSTAGRAM_MAX_STYLE_EXAMPLES=5
INSTAGRAM_MAX_STYLE_EXAMPLE_LENGTH=280
PUBLIC_GENERATION_QUOTA_PER_DAY=12
GATED_DEMO_GENERATION_QUOTA_PER_DAY=40
AUTHENTICATED_GENERATION_QUOTA_PER_DAY=200
ABUSE_BURST_THRESHOLD_PER_MINUTE=30
ABUSE_FAILURE_THRESHOLD_PER_15_MIN=5
ABUSE_VOLUME_THRESHOLD_PER_15_MIN=25
ABUSE_ALERT_COOLDOWN_SECONDS=300
# Optional: set to a list of trusted proxy IPs (comma-separated) so that
# X-Forwarded-For is only honoured from those hosts. Leave empty to trust
# any X-Forwarded-For header (suitable for open/dev deployments).
# TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2
# Maximum number of unique client IPs tracked in-memory per guard store.
# GUARD_MAX_TRACKED_CLIENTS=50000
