# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# App
ENVIRONMENT=development
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=https://neoxra.com,https://www.neoxra.com,http://localhost:3000
NEOXRA_CORE_GIT_URL=https://github.com/Meridian-Global/neoxra-core.git
NEOXRA_CORE_GIT_REF=main
# Required in Render if neoxra-core is private
GITHUB_TOKEN=

# Generation safety limits
CORE_RUN_RATE_LIMIT_PER_MINUTE=12
CORE_RUN_MAX_CONCURRENT_PER_IP=1
CORE_RUN_MAX_BODY_BYTES=8192
CORE_RUN_MAX_IDEA_LENGTH=400
CORE_RUN_MAX_VOICE_PROFILE_LENGTH=64
INSTAGRAM_GENERATE_RATE_LIMIT_PER_MINUTE=20
INSTAGRAM_GENERATE_MAX_CONCURRENT_PER_IP=2
INSTAGRAM_GENERATE_MAX_BODY_BYTES=16384
INSTAGRAM_MAX_TOPIC_LENGTH=240
INSTAGRAM_MAX_TEMPLATE_TEXT_LENGTH=2000
INSTAGRAM_MAX_STYLE_EXAMPLES=5
INSTAGRAM_MAX_STYLE_EXAMPLE_LENGTH=280
# Optional: set to a list of trusted proxy IPs (comma-separated) so that
# X-Forwarded-For is only honoured from those hosts. Leave empty to trust
# any X-Forwarded-For header (suitable for open/dev deployments).
# TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2
# Maximum number of unique client IPs tracked in-memory per guard store.
# GUARD_MAX_TRACKED_CLIENTS=50000

# Optional: platform publishing (day 9+)
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_PERSON_URN=

# Gmail idea scanner
# 1. Create a project at console.cloud.google.com
# 2. Enable the Gmail API
# 3. Create OAuth credentials (Desktop app) and download as credentials.json
# 4. Run: cd backend && python scripts/gmail_auth.py
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
